library ieee;
use ieee.std_logic_1164.all;

entity fourToOneMux is 
	port (
		a,b,c,d : in std_logic;
		s : in std_logic_vector(1 downto 0);
		y : out std_logic
	);
end fourToOneMux;

architecture bhv of fourToOneMux is 
begin 

process(a,b,c,d,s)
begin
	with s select 
		y <= a when "00" ,
		y <= b when "01" ,
		y <= c when "10" ,
		y <= d when "11" 
end process;
end bhv;