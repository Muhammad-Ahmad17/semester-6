<tnetlist_cmd>quartus_eda --write_settings_files=off --simulation --functional=off --flatten_buses=off --timescale=1ps --tool=modelsim_oem --format=vhdl --output_directory="/home/muhammad-ahmad/Desktop/semester-6/DSD/lab/labs/lab2/warningSystem/simulation/qsim/" warningAlaram -c warningAlaram</tnetlist_cmd>
<modelsim_script>onerror {exit -code 1}
vlib work
vcom -work work warningAlaram.vho
